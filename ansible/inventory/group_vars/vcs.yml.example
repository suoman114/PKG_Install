# LTE-R 녹취서버 시크릿 (그룹 변수 — vcs 그룹 전체 자동 로드)
#
# 사용법:
#   1) 이 파일을 같은 폴더에 `vcs.yml`로 복사 (또는 대시보드 "시크릿" 패널에서 저장)
#   2) 값을 현장 비밀번호로 교체
#   3) `vcs.yml`은 .gitignore 처리됨(커밋 금지). 강화 시 ansible-vault 암호화 권장:
#        ansible-vault encrypt ansible/inventory/group_vars/vcs.yml
#
# 평문 비밀번호를 플레이북에서 제거(백로그 완료)하고 이 변수들로 외부화했다.
# 플레이북 참조: 0(ssh), 8-1(mariadb root/vcsm), 8-3(복제), 6(rabbitmq vcm)

ssh_password: "root.123"              # 0_auto_pass: 초기 SSH 접속 비밀번호
mariadb_root_password: "root.123"     # 8-1: MariaDB root
mariadb_vcsm_password: "vcsm.123"     # 8-1: VCSM DB 계정
replication_password: "repl.123"      # 8-3: Master-Master 복제 계정
rmq_vcm_password: "vcm.123"           # 6:   RabbitMQ vcm 계정
vcs_os_password: "vcs.123"            # 9-1:  OS 계정 vcs
vcweb_os_password: "vcweb.123"        # 10-1: OS 계정 vcweb
# account_salt: "lterVcsSalt"         # (선택) OS 계정 해시 salt — 멱등성 위해 고정. 미설정 시 기본값.
